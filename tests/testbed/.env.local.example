# testbed/.env.local.example — copy to .env.local and fill in.
# .env.local is gitignored; never commit a populated copy.
#
#   cp .env.local.example .env.local && $EDITOR .env.local

# Azure subscription + tenant the bed deploys into.
AZ_SUBSCRIPTION=00000000-0000-0000-0000-000000000000
AZ_TENANT=00000000-0000-0000-0000-000000000000

# Resource group + region. RESOURCE_GROUP is deleted wholesale on teardown.
RESOURCE_GROUP=JACO
LOCATION=centralus

# SSH key is MINTED automatically per build into testbed/.ssh/jaco (gitignored),
# so you don't need to provide one. To bring your own instead, set
# ADMIN_PUBLIC_KEY to an OpenSSH public key and manage the matching private key
# yourself (point SSH_KEY at it for the bench/bootstrap).
# ADMIN_PUBLIC_KEY=ssh-ed25519 AAAA... you

# Optional: restrict SSH (22) to your operator IP/CIDR instead of the whole
# internet, e.g. 203.0.113.4/32. Leave unset for an open bed.
# SSH_SOURCE_CIDR=Internet

# Optional: email for daily auto-shutdown notifications. Empty disables them.
# SHUTDOWN_NOTIFICATION_EMAIL=you@example.com

# Prefix for VMs/LB/NSG/PIPs. Stays `jaco` (default) — no per-rebuild rotation
# is needed now that Tailscale is gone. Override only to run a parallel bed
# alongside an existing one.
# VM_NAME_PREFIX=jaco
