{
  "apps": {
    "http": {
      "servers": {
        "jaco_http": {
          "automatic_https": {
            "disable": true
          },
          "listen": [
            ":80"
          ],
          "routes": [
            {
              "handle": [
                {
                  "handler": "reverse_proxy",
                  "health_checks": {
                    "passive": {
                      "fail_duration": "10s"
                    }
                  },
                  "load_balancing": {
                    "retries": 2,
                    "selection_policy": {
                      "policy": "random"
                    },
                    "try_duration": "0s"
                  },
                  "upstreams": [
                    {
                      "dial": "10.244.5.2:80"
                    }
                  ]
                }
              ],
              "match": [
                {
                  "host": [
                    "internal.example.com"
                  ]
                }
              ]
            },
            {
              "handle": [
                {
                  "handler": "static_response",
                  "headers": {
                    "Server": [
                      "jaco"
                    ]
                  },
                  "status_code": 404
                }
              ]
            }
          ]
        },
        "jaco_https": {
          "automatic_https": {
            "disable": true
          },
          "listen": [
            ":443"
          ],
          "routes": [
            {
              "handle": [
                {
                  "handler": "reverse_proxy",
                  "health_checks": {
                    "passive": {
                      "fail_duration": "10s"
                    }
                  },
                  "load_balancing": {
                    "retries": 2,
                    "selection_policy": {
                      "policy": "random"
                    },
                    "try_duration": "0s"
                  },
                  "upstreams": [
                    {
                      "dial": "10.244.5.2:80"
                    }
                  ]
                }
              ],
              "match": [
                {
                  "host": [
                    "internal.example.com"
                  ]
                }
              ]
            },
            {
              "handle": [
                {
                  "handler": "static_response",
                  "headers": {
                    "Server": [
                      "jaco"
                    ]
                  },
                  "status_code": 404
                }
              ]
            }
          ]
        }
      }
    }
  }
}