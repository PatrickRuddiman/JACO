{
  "apps": {
    "http": {
      "servers": {
        "jaco_http": {
          "automatic_https": {
            "disable_redirects": true
          },
          "listen": [
            ":80"
          ],
          "routes": [
            {
              "handle": [
                {
                  "handler": "jaco_acme_challenge"
                }
              ],
              "match": [
                {
                  "path": [
                    "/.well-known/acme-challenge/*"
                  ]
                }
              ]
            },
            {
              "handle": [
                {
                  "handler": "static_response",
                  "headers": {
                    "Location": [
                      "https://{http.request.host}{http.request.uri}"
                    ]
                  },
                  "status_code": 308
                }
              ],
              "match": [
                {
                  "host": [
                    "web.example.com"
                  ],
                  "not": [
                    {
                      "path": [
                        "/.well-known/acme-challenge/*"
                      ]
                    }
                  ]
                }
              ]
            },
            {
              "handle": [
                {
                  "handler": "static_response",
                  "headers": {
                    "Server": [
                      "jaco"
                    ]
                  },
                  "status_code": 404
                }
              ]
            }
          ]
        },
        "jaco_https": {
          "automatic_https": {
            "disable_redirects": true
          },
          "listen": [
            ":443"
          ],
          "routes": [
            {
              "handle": [
                {
                  "handler": "reverse_proxy",
                  "health_checks": {
                    "passive": {
                      "fail_duration": "10s"
                    }
                  },
                  "load_balancing": {
                    "retries": 2,
                    "selection_policy": {
                      "policy": "random"
                    },
                    "try_duration": "0s"
                  },
                  "upstreams": [
                    {
                      "dial": "10.244.5.2:8080"
                    },
                    {
                      "dial": "10.244.5.3:8080"
                    }
                  ]
                }
              ],
              "match": [
                {
                  "host": [
                    "web.example.com"
                  ]
                }
              ]
            },
            {
              "handle": [
                {
                  "handler": "static_response",
                  "headers": {
                    "Server": [
                      "jaco"
                    ]
                  },
                  "status_code": 404
                }
              ]
            }
          ]
        }
      }
    },
    "tls": {
      "automation": {
        "policies": [
          {
            "issuers": [
              {
                "ca": "https://acme-v02.api.letsencrypt.org/directory",
                "challenges": {
                  "http": {},
                  "tls-alpn": {
                    "disabled": true
                  }
                },
                "email": "ops@example.com",
                "module": "acme"
              }
            ],
            "key_type": "p256",
            "storage": {
              "module": "jaco"
            },
            "subjects": [
              "web.example.com"
            ]
          }
        ]
      }
    }
  }
}