{
  "apps": {
    "http": {
      "servers": {
        "jaco_http": {
          "automatic_https": {
            "disable": true
          },
          "listen": [
            ":80"
          ],
          "routes": [
            {
              "handle": [
                {
                  "handler": "static_response",
                  "headers": {
                    "Server": [
                      "jaco"
                    ]
                  },
                  "status_code": 404
                }
              ]
            }
          ]
        },
        "jaco_https": {
          "automatic_https": {
            "disable": true
          },
          "listen": [
            ":443"
          ],
          "routes": [
            {
              "handle": [
                {
                  "handler": "static_response",
                  "headers": {
                    "Server": [
                      "jaco"
                    ]
                  },
                  "status_code": 404
                }
              ]
            }
          ]
        }
      }
    }
  }
}