add table inet jaco
delete table inet jaco
table inet jaco {
    set dep_net_app_backend {
        type ipv4_addr
        flags interval
        elements = { 10.244.7.0/24 }
    }

    set dep_net_app_frontend {
        type ipv4_addr
        flags interval
        elements = { 10.244.5.0/24, 10.244.6.0/24 }
    }

    set jaco_pool {
        type ipv4_addr
        flags interval
        elements = { 10.244.5.0/24, 10.244.6.0/24, 10.244.7.0/24 }
    }

    chain forward {
        type filter hook forward priority 0; policy accept;
        ct state established,related accept
        ip saddr @dep_net_app_backend ip daddr @dep_net_app_backend accept
        ip saddr @dep_net_app_frontend ip daddr @dep_net_app_frontend accept
        ip saddr @jaco_pool ip daddr @jaco_pool drop
    }

    chain input {
        type filter hook input priority 0; policy accept;
    }

    chain output {
        type filter hook output priority 0; policy accept;
    }
}
